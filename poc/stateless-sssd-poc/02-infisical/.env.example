# Copy to .env and fill in. NEVER commit the real .env.

# openssl rand -hex 16
ENCRYPTION_KEY=REPLACE_WITH_openssl_rand_hex_16

# openssl rand -base64 32
AUTH_SECRET=REPLACE_WITH_openssl_rand_base64_32

# Postgres password used by docker-compose.yml
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# External URL the boot clients will use
SITE_URL=http://infisical.poc.lan:8080

# SMTP optional for a POC (invites can be skipped)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_ADDRESS=
